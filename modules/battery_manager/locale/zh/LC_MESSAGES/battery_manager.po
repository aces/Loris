msgid "Battery Manager"
msgstr "电池管理器"

msgid "Submission successful!"
msgstr "提交成功！"

msgid "Instrument"
msgstr "量表/评估工具"

msgid "Minimum Age"
msgstr "最低年龄"

msgid "Maximum Age"
msgstr "最大年龄"

msgid "Stage"
msgstr "阶段"

msgid "First Visit"
msgstr "第一次访问"

msgid "Instrument Order"
msgstr "量表顺序"

msgid "Double Data Entry Enabled"
msgstr "启用双数据输入"

msgid "Change Status"
msgstr "更改状态"

msgid "Edit Metadata"
msgstr "编辑元数据"

msgid "Deactivate"
msgstr "停用"

msgid "Activate"
msgstr "激活"

msgid "Edit"
msgstr "编辑"

msgid "New Test"
msgstr "新测试"

msgid "Edit Test"
msgstr "编辑测试"

msgid "Add New Test"
msgstr "添加新测试"

msgid "This field is required"
msgstr "此字段是必需的"

msgid "This field must be 0 or greater"
msgstr "该字段必须为 0 或更大"

msgid "Minimum age must be lesser than maximum age."
msgstr "最低年龄必须小于最高年龄。"

msgid "Maximum age must be greater than minimum age."
msgstr "最大年龄必须大于最小年龄。"

msgid "Test Duplicate"
msgstr "测试重复"

msgid ""
"The information provided corresponds with a deactivated test that already "
"exists in the system."
msgstr "提供的信息与系统中已存在的已停用测试相对应。"

msgid "Would you to like activate that test?"
msgstr "您想激活该测试吗？"

msgid "You cannot duplicate an active test"
msgstr "您不能重复正在进行的测试"

msgid ""
"You cannot add an entry if it has a duplicate entry in the test battery."
msgstr "如果测试电池中有重复条目，则无法添加条目。"

msgid ""
"If the duplicate entry is inactive, you will be given the option to activate"
" it."
msgstr "如果重复条目处于非活动状态，您将可以选择激活它。"

msgid "Editing an entry will alter the current entry."
msgstr "编辑条目将更改当前条目。"

msgid ""
"You cannot edit an entry to have the same values as another active entry."
msgstr "您无法编辑一个条目以使其具有与另一个活动条目相同的值。"

msgid "Search for instrument"
msgstr "搜索量表"

msgid "Search for site"
msgstr "搜索站点"

msgid "Enable Double Data Entry"
msgstr "启用双重数据输入"

msgid "Submit"
msgstr "提交"

msgid "Maximum Age (days)"
msgstr "最长年龄（天）"

msgid "Minimum Age (days)"
msgstr "最低年龄（天）"
