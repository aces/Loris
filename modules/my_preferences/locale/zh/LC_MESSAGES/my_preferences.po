msgid "Edit My Information"
msgstr "编辑我的信息"

msgid "Notifications"
msgstr "通知"

msgid "Your email address must be less than 255 characters long"
msgstr "您的电子邮件地址长度必须少于 255 个字符"

msgid "Language preference"
msgstr "语言偏好"

msgid "Operation"
msgstr "手术"

msgid "Description"
msgstr "描述"

msgid "The email address already exists"
msgstr "该电子邮件地址已存在"

msgid "Your password cannot be your email"
msgstr "您的密码不能是您的电子邮件"

msgid "Your password cannot be your username"
msgstr "您的密码不能是您的用户名"

msgid "The passwords do not match"
msgstr "密码不匹配"

msgid "New and old passwords are identical"
msgstr "新旧密码相同"

msgid "Configure multi-factor authentication (MFA)"
msgstr "配置多重身份验证 (MFA)"

msgid "Configure MFA"
msgstr "配置MFA"

msgid "Manual MFA Setup"
msgstr "手动 MFA 设置"

msgid "Use the following key in your authenticator app: <0>{{code}}</0>"
msgstr "在您的身份验证器应用中使用以下密钥：<0> {{code}} </0>"

msgid ""
"Scan the following QR code below in your MFA authenticator and enter the "
"code to validate."
msgstr "在 MFA 身份验证器中扫描下面的二维码并输入该代码进行验证。"

msgid ""
"Note that this will <0>overwrite</0> any previously setup MFA in LORIS!"
msgstr "请注意，这将<0>覆盖</0>之前在 LORIS 中设置的任何 MFA！"

msgid "Can't scan the QR code? <0>Setup manually.</0>"
msgstr "无法扫描二维码？ <0>手动设置。</0>"

msgid "Validate Code"
msgstr "验证码"

msgid "Successfully registered multifactor authenticator"
msgstr "已成功注册多因素身份验证器"
