msgid "Invalid extension. Only .linst files are allowed."
msgstr "文件扩展名无效，仅允许 .linst 文件。"

msgid "Spaces are not allowed in the file name."
msgstr "文件名中不能包含空格。"

msgid "Multiple periods in the file name are not allowed."
msgstr "文件名中不能包含多个点号。"

msgid "Special characters are not allowed (only letters, numbers, and _)."
msgstr "文件名不能包含特殊字符（仅允许字母、数字和下划线）。"

msgid "File name cannot end with a special character."
msgstr "文件名不能以特殊字符结尾。"

