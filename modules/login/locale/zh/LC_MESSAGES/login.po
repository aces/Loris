msgid "Login"
msgstr "登录"

msgid "Login to LORIS"
msgstr "登录洛里斯"

msgid "Forgot your password?"
msgstr "忘记密码了吗？"

msgid "Request Account"
msgstr "请求帐户"

msgid "Multifactor authentication required"
msgstr "需要多重身份验证"

msgid "Enter the code from your authenticator app below to proceed."
msgstr "输入下面验证器应用程序中的代码以继续。"

msgid "Data in LORIS:"
msgstr "LORIS 中的数据："

msgid ""
"Please enter your username below, and a new password will be sent to you."
msgstr "请在下面输入您的用户名，新密码将发送给您。"

msgid "Back to login page"
msgstr "返回登录页面"

msgid "Reset Password"
msgstr "重置密码"

msgid "Thank you!"
msgstr "谢谢你！"

msgid "Password reset. You should receive an email within a few minutes."
msgstr "密码重置。您应该会在几分钟内收到一封电子邮件。"

msgid "Return to Login Page"
msgstr "返回登录页面"

msgid "Choose your site:"
msgstr "选择您的网站："

msgid "Choose your project:"
msgstr "选择您的项目："

msgid "Preferred language:"
msgstr "首选语言："

msgid "Radiologist"
msgstr "放射科医生"

msgid "Examiner role"
msgstr "考官角色"

msgid ""
"Please fill in the form below to request a LORIS account. We will contact "
"you once your account has been approved."
msgstr "请填写下面的表格来申请 LORIS 帐户。您的帐户获得批准后，我们​​将与您联系。"

msgid "Your request for an account has been received successfully."
msgstr "您的帐户请求已成功收到。"

msgid "Please contact your project administrator to activate this account."
msgstr "请联系您的项目管理员激活此帐户。"

msgid "View {{policy}}"
msgstr "查看{{policy}}"

msgid "{{title}} not accepted"
msgstr "{{title}} 不被接受"

msgid "You must accept the {{title}} before requesting an account."
msgstr "在请求帐户之前，您必须接受 {{title}}。"

